# Docebo REST API Patterns — HCP Portal Backend

## API Architecture

- **Base URL**: `https://merzaestheticsexchangesandbox.docebosaas.com`
- **API Browser**: `https://merzaestheticsexchangesandbox.docebosaas.com/api-browser/`
- **Auth**: OAuth2 Bearer token (see `docebo-auth-sso.mdc` for token acquisition)
- **Format**: JSON request/response
- **Rate limits**: Platform-dependent; handle HTTP 429 with exponential backoff

## API Services Overview

| Service | Base Path | Scope |
|---|---|---|
| **manage** | `/manage/v1/` | Users, branches (org chart), groups, power users |
| **learn** | `/learn/v1/` | Courses, enrollments, catalogs, training materials, learning plans |
| **course** | `/course/v1/` | Course creation/update, sections, prerequisites |
| **learningplan** | `/learningplan/v1/` | Learning plan management and enrollment |
| **certification** | `/manage/v1/` | Certification records (under manage service) |
| **analytics** | `/analytics/v1/` | Reports, exports, scheduled reports |
| **gamification** | `/gamification/v1/` | Badges, points, leaderboards |
| **social** | `/social/v1/` | Channels, assets, community content |

## PHP HTTP Client Base Class

```php
<?php
// EXT:hcp_portal/Classes/Service/DoceboApiClient.php

namespace Merz\HcpPortal\Service;

class DoceboApiClient
{
    private string $baseUrl = 'https://merzaestheticsexchangesandbox.docebosaas.com';
    private string $accessToken;
    private DoceboTokenService $tokenService;

    public function __construct(DoceboTokenService $tokenService)
    {
        $this->tokenService = $tokenService;
    }

    /**
     * Make an authenticated API request to Docebo.
     *
     * @param string $method  HTTP method (GET, POST, PUT, DELETE)
     * @param string $path    API path (e.g., '/learn/v1/courses')
     * @param array  $params  Query params (GET) or body (POST/PUT)
     * @param array  $query   Additional query string params for POST/PUT
     * @return array Decoded JSON response
     * @throws DoceboApiException
     */
    public function request(
        string $method,
        string $path,
        array $params = [],
        array $query = []
    ): array {
        $this->ensureToken();

        $url = $this->baseUrl . $path;

        // Add query string for GET or additional query params
        if ($method === 'GET' && !empty($params)) {
            $url .= '?' . http_build_query($params);
        } elseif (!empty($query)) {
            $url .= '?' . http_build_query($query);
        }

        $ch = curl_init($url);
        $headers = [
            'Authorization: Bearer ' . $this->accessToken,
            'Content-Type: application/json',
            'Accept: application/json'
        ];

        $options = [
            CURLOPT_RETURNTRANSFER => true,
            CURLOPT_HTTPHEADER => $headers,
            CURLOPT_TIMEOUT => 30,
        ];

        if ($method === 'POST') {
            $options[CURLOPT_POST] = true;
            $options[CURLOPT_POSTFIELDS] = json_encode($params);
        } elseif ($method === 'PUT') {
            $options[CURLOPT_CUSTOMREQUEST] = 'PUT';
            $options[CURLOPT_POSTFIELDS] = json_encode($params);
        } elseif ($method === 'DELETE') {
            $options[CURLOPT_CUSTOMREQUEST] = 'DELETE';
        }

        curl_setopt_array($ch, $options);
        $response = curl_exec($ch);
        $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
        curl_close($ch);

        if ($httpCode === 429) {
            // Rate limited — implement exponential backoff
            throw new DoceboRateLimitException('Rate limit exceeded');
        }

        $decoded = json_decode($response, true);

        if ($httpCode >= 400) {
            throw new DoceboApiException(
                $decoded['error'] ?? 'Unknown error',
                $httpCode,
                $decoded
            );
        }

        return $decoded;
    }

    /**
     * Paginated GET — fetches all pages automatically.
     * WARNING: Use with caution for large datasets; prefer cursor-based pagination.
     *
     * @param string $path   API path
     * @param array  $params Base query params
     * @param int    $pageSize Items per page (max 200)
     * @return array All items collected across pages
     */
    public function getAllPages(
        string $path,
        array $params = [],
        int $pageSize = 200
    ): array {
        $allItems = [];
        $page = 1;
        $params['page_size'] = $pageSize;

        do {
            $params['page'] = $page;
            $response = $this->request('GET', $path, $params);

            $items = $response['data']['items'] ?? $response['data'] ?? [];
            $allItems = array_merge($allItems, $items);

            $hasMore = $response['data']['has_more_data'] ?? false;
            $page++;
        } while ($hasMore);

        return $allItems;
    }

    /**
     * Cursor-based pagination (recommended for large datasets).
     */
    public function getAllWithCursor(
        string $path,
        array $params = [],
        int $pageSize = 200
    ): array {
        $allItems = [];
        $params['page_size'] = $pageSize;
        $params['get_cursor'] = 1;
        $cursor = null;

        do {
            if ($cursor) {
                $params['cursor'] = $cursor;
            }
            $response = $this->request('GET', $path, $params);

            $items = $response['data']['items'] ?? $response['data'] ?? [];
            $allItems = array_merge($allItems, $items);

            $cursor = $response['data']['cursor'] ?? null;
            $hasMore = $response['data']['has_more_data'] ?? false;
        } while ($hasMore && $cursor);

        return $allItems;
    }

    private function ensureToken(): void
    {
        if (empty($this->accessToken) || $this->tokenService->isExpired()) {
            $this->accessToken = $this->tokenService->getServiceToken();
        }
    }
}
```

## User Management (manage service)

```php
// --- CREATE USER ---
$result = $api->request('POST', '/manage/v1/user', [
    'userid' => 'hcp_12345',               // Username (unique)
    'email' => 'dr.smith@clinic.com',
    'password' => bin2hex(random_bytes(16)), // Auto-generated, user logs in via SSO
    'firstname' => 'John',
    'lastname' => 'Smith',
    'role' => 'learner',                    // learner | poweruser | superadmin
    'branch_id' => 42,                      // Extended Enterprise branch (see EMEA rule)
    'language' => 'english',
    'valid' => true                         // Active immediately
    // Additional fields: 'field_1' => 'value' (platform-specific custom fields)
]);
$doceboUserId = $result['data']['user_id'];

// --- GET USER BY EMAIL ---
$users = $api->request('GET', '/manage/v1/user', [
    'search_text' => 'dr.smith@clinic.com',
    'page_size' => 1
]);

// --- UPDATE USER ---
$api->request('PUT', '/manage/v1/user/' . $doceboUserId, [
    'firstname' => 'Jonathan',
    'branch_id' => 55 // Move to different branch/cluster
]);

// --- DEACTIVATE USER ---
$api->request('PUT', '/manage/v1/user/' . $doceboUserId, [
    'valid' => false
]);

// --- BATCH USER CREATION ---
$api->request('POST', '/manage/v1/user/batch', [
    'items' => [
        ['userid' => 'hcp_001', 'email' => 'a@b.com', 'firstname' => 'A', 'lastname' => 'B', 'branch_id' => 42],
        ['userid' => 'hcp_002', 'email' => 'c@d.com', 'firstname' => 'C', 'lastname' => 'D', 'branch_id' => 42],
    ]
]);
```

## Courses & Enrollment (learn service)

```php
// --- LIST ALL COURSES ---
$courses = $api->request('GET', '/learn/v1/courses', [
    'page_size' => 50,
    'sort_attr' => 'name',
    'sort_dir' => 'asc'
]);

// --- GET SINGLE COURSE ---
$course = $api->request('GET', '/learn/v1/courses/' . $courseId);

// --- GET COURSE ENROLLMENTS ---
$enrollments = $api->request('GET', '/learn/v1/enrollments', [
    'id_course' => $courseId,
    'page_size' => 200
]);

// --- ENROLL USER IN COURSE ---
$api->request('POST', '/learn/v1/enrollment/batch', [
    'items' => [
        [
            'user_id' => $doceboUserId,
            'course_id' => $courseId,
            'status' => 0  // 0=subscribed, 1=in_progress, 2=completed
        ]
    ]
]);

// --- GET USER'S ENROLLMENTS ---
$userEnrollments = $api->request('GET', '/learn/v1/enrollments', [
    'id_user' => $doceboUserId,
    'page_size' => 200
]);

// --- MARK ENROLLMENT COMPLETE (batch update) ---
$api->request('POST', '/learn/v1/enrollment/batch', [
    'items' => [
        [
            'user_id' => $doceboUserId,
            'course_id' => $courseId,
            'status' => 2,  // completed
            'date_complete' => '2026-03-26 12:00:00'
        ]
    ]
]);

// --- TRACK LEARNING OBJECT COMPLETION ---
$api->request('POST', '/learn/v1/lo/' . $loId . '/track', [
    'user_id' => $doceboUserId,
    'status' => 'completed',
    'score' => 95
]);
```

